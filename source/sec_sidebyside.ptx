<section>
  <title>SideBySide for Layout</title>
  <slide>
    <title>Cardinality</title>
    <sbsgroup widths="25% 70%">
      <sidebyside>
        <image label="card-inject">
          <shortdescription component="a">An arrow diagram for an injective function</shortdescription>
          <description component="a">
            <p>A set <m>X=\set{a,b,c}</m> and a set <m>Y=\set{5,6,7,8}</m> with a function <m>f\colon X\to Y</m> defined by <m>f(a)=5</m>, <m>f(b)=7</m>, and <m>f(c)=8</m>.
            </p>
          </description>
          <latex-image>
            \begin{tikzpicture}
            \foreach[count=\i] \lseti/\lsetmi in {X/{$a$,$b$,$c$},Y/{5,6,7,8}} {
              \begin{scope}[local bounding box=\lseti, x=2cm, y=0.5cm]
              \foreach[count=\j] \lj in \lsetmi {
                \node[minimum width=1em] (n-\j-\lseti) at (\i,-\j) {\lj};
              }
              \end{scope}
              \node[ellipse, draw, fit=(\lseti), 
              label={[name=l-\lseti]above:$\lseti$}] {};
            }
            \draw[->] (n-1-X) -- (n-1-Y);
            \draw[->] (n-2-X) -- (n-3-Y);
            \draw[->] (n-3-X) -- (n-4-Y);
            \draw[->] (l-X) -- node[above]{$f$}(l-X.center-|l-Y.west);
            \end{tikzpicture}     
          </latex-image>
        </image>
        <p>
          If <m>f\colon X\to Y</m> is injective, then
          <md component="a">
            |X|\leq |Y|
          </md>
          <md component="b">
            |X|\phantom{\leq} |Y|
          </md>
        </p>
      </sidebyside>
      <sidebyside>
        <image label="card-surject">
          <shortdescription component="a">An arrow diagram for a surjective function</shortdescription>
          <description component="a">
            <p>A set <m>X=\set{a,b,c,d}</m> and a set <m>Y=\set{5,6,7}</m> with a function <m>f\colon X\to Y</m> defined by <m>f(a)=5</m>, <m>f(b)=5</m>, <m>f(c)=7</m>, <m>f(d)=6</m>.
            </p>
          </description>
          <latex-image>
            \begin{tikzpicture} 
            \foreach[count=\i] \lseti/\lsetmi in {X/{$a$,$b$,$c$,$d$},Y/{5,6,7}} {
              \begin{scope}[local bounding box=\lseti, x=2cm, y=0.5cm]
              \foreach[count=\j] \lj in \lsetmi {
                \node[minimum width=1em] (n-\j-\lseti) at (\i,-\j) {\lj};
              }
              \end{scope}
              \node[ellipse, draw, fit=(\lseti), 
              label={[name=l-\lseti]above:$\lseti$}] {};
            }
            \draw[->] (n-1-X) -- (n-1-Y);
            \draw[->] (n-2-X) -- (n-1-Y);
            \draw[->] (n-3-X) -- (n-3-Y);
            \draw[->] (n-4-X) -- (n-2-Y);
            \draw[->] (l-X) -- node[above]{$f$}(l-X.center-|l-Y.west);
            \end{tikzpicture}     
          </latex-image>
        </image>
        <p>
          If <m>f\colon X\to Y</m> is surjective, then
          <md component="a">
            |X|\geq |Y|
          </md>
          <md component="b">
            |X|\phantom{\geq} |Y|
          </md>
        </p>
      </sidebyside>
    </sbsgroup>
  </slide>
  <slide>
    <title>Empty Space On the Side</title>
    <sidebyside widths="30% 70%">
      <image>
        <description component="a">
          <p>
            A multigraph with four vertices. There are two edges between vertices 1 and 2. The other edges are <m>\set{1,3}</m>, <m>\set{2,4}</m>, and <m>\set{3,4}</m>.
          </p>
        </description>
        <prefigure xmlns="https://prefigure.org" label="neighbors">
          <diagram dimensions="(250,250)" margins="5">
            <definition>graph={1:[2,2,3],2:[4],3:[4],4:[]}</definition>
            <coordinates bbox="(-1,-1,1,1)">
              <network graph="graph" scale="0.8"
              node-fill="#fcf" node-stroke="black"
              seed="1" labels="yes" 
              tactile-node-size="40">
              
            </network>
          </coordinates>
        </diagram>
      </prefigure>
    </image>
    <p component="b">
      <nbsp/>
    </p>
    <p component="a">
      <ul>
        <li>
          <p >
            The neighbors of <m>1</m> are <m>2</m> and <m>3</m>
          </p>
          
        </li>
        <li>
          <p>
            <m>1</m> and <m>4</m> are not adjacent
          </p>
        </li>
        <li>
          <p>
            <m>\deg(1)=3</m>, <m>\deg(2)=3</m>, <m>\deg(3)=2</m>, <m>\deg(4)=2</m>
          </p>
        </li>
      </ul>
    </p>
  </sidebyside>
</slide>
</section>